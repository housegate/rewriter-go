    "want_code": "Success",
    "want_table_rewrites": {"tenant1.events": "testnet.tenant1.events"},
    "want_failed_cte_aliases": [],
    "want_sql": "WITH c AS (SELECT * FROM testnet.\"tenant1.events\") SELECT * FROM c"
  },
  {
